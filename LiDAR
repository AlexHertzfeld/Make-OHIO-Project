#include <Arduino.h>

#include <Wire.h>

#include <vl53l4cd_class.h>

// Initialize the sensor (using -1 for XSHUT if it's hardwired to 3.3V)

VL53L4CD sensor_vl53l4cd(&Wire, -1);

void setup() {

Serial.begin(115200);

while (!Serial); 


// Standard ESP32 I2C pins

Wire.begin(21, 22); 


Serial.println("--- VL53L4CD High-Sensitivity Test ---");


if (sensor_vl53l4cd.begin() != 0) {

Serial.println("Sensor failed to begin. Check your wiring on Pins 21 and 22.");

while (1);

}



// Increased from 50ms to 200ms to handle "Weak Signal" errors.

// This gives the sensor more time to collect infrared photons.

sensor_vl53l4cd.VL53L4CD_SetRangeTiming(200, 0);

  sensor_vl53l4cd.VL53L4CD_StartRanging();

  Serial.println("Sensor Online. Point it at a flat, light-colored surface 20cm away.");

}

void loop() {

uint8_t NewDataReady = 0;

VL53L4CD_Result_t results;

  sensor_vl53l4cd.VL53L4CD_CheckForDataReady(&NewDataReady);

  if (NewDataReady) {

sensor_vl53l4cd.VL53L4CD_GetResult(&results);

sensor_vl53l4cd.VL53L4CD_ClearInterrupt();

// Status 0 means a perfect reading

if (results.range_status == 0) {

Serial.print("Distance: ");

Serial.print(results.distance_mm);

Serial.print(" mm");

Serial.print("  (");

Serial.print(results.distance_mm / 10.0);

Serial.println(" cm)");

} 

else {

// If it fails, print the specific status code for troubleshooting

Serial.print("Signal Issue. Status Code: ");

Serial.print(results.range_status); 

Serial.println(" (Check for plastic film or target distance)");

}

}

delay(50); 

}
